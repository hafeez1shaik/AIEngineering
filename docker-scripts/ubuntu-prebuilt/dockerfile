# Use the latest Ubuntu 24.04 Desktop image
FROM accetto/ubuntu-vnc-xfce-g3:24.04

USER root

# 1. Fix the "Snap" problem for Firefox via PPA
RUN apt-get update && apt-get install -y software-properties-common && \
    add-apt-repository ppa:mozillateam/ppa -y && \
    echo 'Package: *\nPin: release o=LP-PPA-mozillateam\nPin-Priority: 1001' > /etc/apt/preferences.d/mozilla-firefox

# 2. Install Java 21, Python 3.12, and VNC Tools
RUN apt-get update && apt-get install -y --no-install-recommends \
    openjdk-21-jdk \
    python3 \
    python3-pip \
    python3-venv \
    firefox \
    wget \
    gpg \
    ca-certificates \
    tightvncserver \
    && rm -rf /var/lib/apt/lists/*

# 3. Create .vnc folder and pre-bake the password
RUN mkdir -p /home/headless/.vnc && \
    echo "password123" | vncpasswd -f > /home/headless/.vnc/passwd && \
    chmod 600 /home/headless/.vnc/passwd

# 4. CRITICAL FIX: Give ownership of ALL system folders back to UID 1001
# This prevents the permission denied errors that cause the restart loop
RUN chown -R 1001:1001 /home/headless /dockerstartup && \
    chmod -R 777 /dockerstartup # Ensures the startup scripts are executable

# 5. Set the alias so 'python' works
RUN ln -s /usr/bin/python3 /usr/bin/python

USER 1001
